# JWT Configuration (shared across all services)
# Must be at least 32 bytes long for HMAC-SHA256
AUTH_JWT_SECRET=change-this-secret-key-to-at-least-32-bytes-long
AUTH_JWT_EXPIRATION_SECONDS=3600

# CORS Configuration
# Comma-separated list of allowed origins (no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Service Ports
AUTH_SERVICE_PORT=8082
CATALOG_SERVICE_PORT=8083
BACKORQUESTER_PORT=8081

# Logging Levels
LOG_LEVEL=INFO
